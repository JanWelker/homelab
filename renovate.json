{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "platformAutomerge": true,
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone",
    ":timezone(Europe/Berlin)"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": "at any time",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "packageRules": [
    {
      "description": "Infrastructure Platform Updates",
      "matchFileNames": [
        "payload/platform/**"
      ],
      "groupName": "Platform Infrastructure",
      "addLabels": [
        "infrastructure"
      ],
      "automerge": true,
      "matchUpdateTypes": [
        "patch"
      ]
    },
    {
      "description": "Application Workload Updates",
      "matchFileNames": [
        "payload/workloads/**"
      ],
      "groupName": "Workloads",
      "addLabels": [
        "application"
      ],
      "automerge": true,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "Python Tooling and Pre-commit",
      "matchPackageNames": [
        "ansible",
        "pre-commit",
        "ansible-lint",
        "pylint",
        "yamllint",
        "mkdocs-material"
      ],
      "groupName": "Dev Tooling",
      "automerge": true,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "DevOps, Automation & CI",
      "matchManagers": [
        "ansible",
        "github-actions",
        "custom.regex"
      ],
      "groupName": "DevOps",
      "addLabels": [
        "devops"
      ],
      "automerge": true,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchPackageNames": [
        "!flatcar",
        "!kubernetes",
        "!containerd",
        "!syslinux"
      ]
    },
    {
      "description": "Core Infrastructure (OS, K8s, Containerd)",
      "matchPackageNames": [
        "flatcar",
        "kubernetes",
        "containerd",
        "syslinux"
      ],
      "groupName": "Core Infrastructure",
      "addLabels": [
        "infrastructure"
      ],
      "automerge": false
    },
    {
      "description": "Block all Major updates from automerging",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^payload/.+\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/^payload/.+\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/^payload/.+values\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/inventory\\.yaml$/"
      ],
      "matchStrings": [
        "flatcar_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "flatcar",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/scripts"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/inventory\\.yaml$/"
      ],
      "matchStrings": [
        "kubernetes_version:\\s*['\"]?(?<currentValue>v?[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "kubernetes",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/sysext-bakery"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/inventory\\.yaml$/"
      ],
      "matchStrings": [
        "containerd_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "containerd",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/sysext-bakery"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/inventory\\.yaml$/"
      ],
      "matchStrings": [
        "syslinux_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "syslinux",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "geneh/syslinux"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/templates/.*\\.j2$/"
      ],
      "matchStrings": [
        "image:\\s*['\"]?(?<depName>[^:\"'\\s]+):(?<currentValue>[a-zA-Z0-9_.-]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?['\"]?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yaml$/"
      ],
      "matchStrings": [
        "(?<depName>dag-andersen/argocd-diff-preview):(?<currentValue>[a-zA-Z0-9_.-]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}