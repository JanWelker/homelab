{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone",
    ":timezone(Europe/Berlin)"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "before 5pm every weekday"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "schedule": "at any time"
  },
  "packageRules": [
    {
      "description": "Infrastructure Platform Updates",
      "matchFileNames": [
        "payload/platform/**"
      ],
      "groupName": "Platform Infrastructure",
      "addLabels": [
        "infrastructure"
      ]
    },
    {
      "description": "Application Workload Updates",
      "matchFileNames": [
        "payload/workloads/**"
      ],
      "groupName": "Workloads",
      "addLabels": [
        "application"
      ],
      "automerge": true,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "Python Tooling and Pre-commit",
      "matchPackageNames": [
        "ansible",
        "pre-commit",
        "ansible-lint",
        "pylint",
        "yamllint",
        "mkdocs-material"
      ],
      "groupName": "Dev Tooling",
      "automerge": true
    },
    {
      "description": "Ansible and GitHub Actions",
      "matchManagers": [
        "ansible",
        "github-actions"
      ],
      "groupName": "Automation & CI",
      "addLabels": [
        "devops"
      ]
    },
    {
      "description": "Core Infrastructure (OS, K8s, Containerd)",
      "matchPackageNames": [
        "flatcar",
        "kubernetes",
        "containerd",
        "syslinux"
      ],
      "groupName": "Core Infrastructure",
      "addLabels": [
        "infrastructure"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ]
    }
  ],
  "kubernetes": {
    "fileMatch": [
      "payload/.+\\.yaml$"
    ]
  },
  "argocd": {
    "fileMatch": [
      "payload/.+\\.yaml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "payload/.+values\\.yaml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "ansible/inventory.yml"
      ],
      "matchStrings": [
        "flatcar_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "flatcar",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/scripts"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "ansible/inventory.yml"
      ],
      "matchStrings": [
        "kubernetes_version:\\s*['\"]?(?<currentValue>v?[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "kubernetes",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/sysext-bakery"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "ansible/inventory.yml"
      ],
      "matchStrings": [
        "containerd_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "containerd",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "flatcar/sysext-bakery"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "ansible/inventory.yml"
      ],
      "matchStrings": [
        "syslinux_version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "syslinux",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "geneh/syslinux"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^ansible/templates/.*\\.j2$"
      ],
      "matchStrings": [
        "image:\\s*['\"]?(?<depName>[^:\"'\\s]+):(?<currentValue>[^\"'\\s]+)['\"]?"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}